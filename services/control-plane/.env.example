# GATSV OS Control Plane — environment variables
# Copy to .env and fill in all values before deploying.
# NEVER commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Public base URL of this service (no trailing slash).
# Used to construct Sendblue status_callback URLs.
# Example: https://bot.gatsv.com
APP_BASE_URL=https://YOUR_DOMAIN_HERE

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Sendblue (iMessage transport) ────────────────────────────────────────────
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=+1XXXXXXXXXX
# Random secret you set in the Sendblue webhook URL: ?token=SECRET
SENDBLUE_WEBHOOK_SECRET=

# ── Slack operator surface ────────────────────────────────────────────────────
# Bot token from your Slack app (xoxb-...)
SLACK_BOT_TOKEN=xoxb-
# Signing secret from your Slack app's Basic Information page
SLACK_SIGNING_SECRET=
# Channel ID (not name) of the ops channel — right-click channel → Copy channel ID
SLACK_OPS_CHANNEL_ID=C
# How often the Slack scheduler polls for new approvals and errors (seconds)
SLACK_POLL_INTERVAL_SECONDS=60
# Time (HH:MM, 24h, Pacific) the daily ops summary is posted
SLACK_SUMMARY_TIME_PT=08:00

# ── Proactive messaging ───────────────────────────────────────────────────────
# Jake's phone number for iMessage bot and daily digest
JAKE_PHONE_NUMBER=+1XXXXXXXXXX
# Time (HH:MM, 24h, Pacific) the iMessage daily digest is sent
DIGEST_SEND_TIME_PT=07:00

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_POLL_INTERVAL_SECONDS=60

# ── Postmark (inbound email connector) ───────────────────────────────────────
POSTMARK_INBOUND_WEBHOOK_SECRET=
POSTMARK_SERVER_TOKEN=

# ── Tally (form connector) ────────────────────────────────────────────────────
TALLY_WEBHOOK_SECRET=
