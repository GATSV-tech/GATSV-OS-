# ─────────────────────────────────────────────
# Control plane
# ─────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────
# AI providers
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# Slack (v1 operator surface)
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_OPS_CHANNEL_ID=

# ─────────────────────────────────────────────
# Postmark (inbound + outbound email)
# ─────────────────────────────────────────────
POSTMARK_INBOUND_WEBHOOK_SECRET=
POSTMARK_SERVER_TOKEN=

# ─────────────────────────────────────────────
# Tally (form webhook)
# ─────────────────────────────────────────────
TALLY_WEBHOOK_SECRET=
